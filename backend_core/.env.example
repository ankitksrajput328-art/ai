# --- NEXUS AI ENVIRONMENT TEMPLATE ---
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to Git. It is already in .gitignore.

# =============================================
# CORE AI PROVIDERS
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=sk-xxxx
CLAUDE_API_KEY=sk-ant-xxxx
AI_MODEL=gemini-1.5-pro

# =============================================
# VECTOR MEMORY (PINECONE)
# =============================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX=nexus-memories

# =============================================
# RELATIONAL DATABASE (POSTGRESQL)
# =============================================
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nexus_ai_db

# =============================================
# CACHE & RATE LIMITING (REDIS)
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================
# SECURITY & AUTH
# =============================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=generate_a_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================
# BILLING & PAYMENTS (STRIPE)
# =============================================
STRIPE_API_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# =============================================
# VOICE AI (ELEVENLABS)
# =============================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDqW21m00

# =============================================
# PUSH NOTIFICATIONS (FIREBASE)
# =============================================
FIREBASE_CREDENTIALS_PATH=config/firebase_credentials.json
